APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# على السيرفر المباشر: استخدم رابط الموقع الحقيقي (مثلاً https://yourdomain.com) وإلا لا تظهر الصور
APP_URL=http://localhost

# Google OAuth (تسجيل الدخول / إنشاء حساب طالب بـ Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# قرص ملفات مجتمع الذكاء الاصطناعي (تقديمات المساهمين): local أو r2
FILESYSTEM_DISK_COMMUNITY=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# البريد: لإرسال رمز المصادقة الثنائية (2FA) للأدمن والمدربين عبر SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@mindlytics-academy.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@mindlytics-academy.com
MAIL_FROM_NAME="${APP_NAME}"

# إلزام الأدمن والمدربين بالمصادقة الثنائية (2FA) عبر البريد
ADMIN_2FA_REQUIRED=true

# عام (S3 أو Cloudflare R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
# لـ Cloudflare R2: Endpoint من لوحة R2 → Manage R2 API Tokens
# AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
# رابط عام للتحميل (إن فعّلت Public Access على الـ bucket)
# AWS_URL=https://pub-xxx.r2.dev
AWS_URL=

# بوابة الدفع كاشير — API v3 (Payment Sessions). TEST → test-api.kashier.io ، LIVE → api.kashier.io
KASHIER_MODE=test
KASHIER_TEST_MID=
KASHIER_TEST_API_KEY=
KASHIER_TEST_SECRET=
KASHIER_TEST_BASE_URL=https://checkout.kashier.io
# KASHIER_TEST_API_BASE_URL=https://test-api.kashier.io
KASHIER_LIVE_MID=
KASHIER_LIVE_API_KEY=
KASHIER_LIVE_SECRET=
KASHIER_LIVE_BASE_URL=https://checkout.kashier.io
# KASHIER_LIVE_API_BASE_URL=https://api.kashier.io
KASHIER_CURRENCY=EGP
KASHIER_ALLOWED_METHODS=card,wallet,bank_installments
# رابط العودة بعد الدفع — يجب أن يكون URI صالحاً. للتجربة محلياً: http://127.0.0.1:8000/checkout/kashier/callback
# KASHIER_MERCHANT_REDIRECT_URL=https://yourdomain.com/checkout/kashier/callback

VITE_APP_NAME="${APP_NAME}"
